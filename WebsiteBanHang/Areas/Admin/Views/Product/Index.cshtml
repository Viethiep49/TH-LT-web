@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Danh Sách Sách";
}

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Danh Mục Sách</h2>
            <a asp-area="Admin" asp-action="Add" class="btn btn-primary shadow-sm fw-semibold">
                <i class="fas fa-plus me-1"></i> Thêm Sách Mới
            </a>
        </div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var item in Model) {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 position-relative">
                <div class="text-center p-3 bg-light rounded-top" style="height: 200px;">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="img-fluid h-100 object-fit-contain" alt="@item.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                            <i class="far fa-image fs-1 opacity-25"></i>
                        </div>
                    }
                </div>
                
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold text-truncate mb-1" title="@item.Name">@item.Name</h5>
                    <p class="card-text text-success fw-bold fs-5 mb-3">@item.Price.ToString("#,##0") đ</p>
                    <p class="card-text text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @item.Description
                    </p>
                </div>
                
                <div class="card-footer bg-transparent border-top-0 px-3 pb-3">
                    <div class="d-flex justify-content-between gap-2">
                        <a asp-area="Customer" asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info flex-grow-1" title="Chi tiết">
                            <i class="fas fa-eye"></i> Xem
                        </a>
                        <a asp-area="Admin" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-grow-1" title="Sửa">
                            <i class="fas fa-edit"></i> Sửa
                        </a>
                        <a asp-area="Admin" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger flex-grow-1" title="Xóa">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
