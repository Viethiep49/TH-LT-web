@model WebsiteBanHang.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Cập Nhật Thông Tin Sách";
}

<div class="row layout-center justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Cập Nhật Thông Tin Sách</h2>
            <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary">
               <i class="fas fa-arrow-left"></i> Quay lại danh mục
            </a>
        </div>
        
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Update" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <!-- Giữ lại URL hình ảnh cũ phòng trường hợp không tải lên hình ảnh mới -->
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="row">
                        <div class="col-md-7 pe-md-4">
                            <h5 class="fw-semibold border-bottom pb-2 mb-4">Thông Tin Chi Tiết</h5>
                            
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">Tên Sách</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Price" class="form-label fw-semibold">Giá (đ)</label>
                                    <input asp-for="Price" class="form-control" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-semibold">Danh Mục</label>
                                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                        <option value="">-- Chọn Danh Mục --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label fw-semibold">Mô Tả</label>
                                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-5 border-start ps-md-4 mt-4 mt-md-0">
                            <h5 class="fw-semibold border-bottom pb-2 mb-4">Hình Ảnh Bìa Sách</h5>
                            
                            <div class="text-center mb-4 bg-light rounded p-3" style="min-height: 200px; display: flex; align-items: center; justify-content: center;">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm object-fit-contain" style="max-height: 200px;" alt="Hình ảnh hiện tại" />
                                }
                                else
                                {
                                    <div class="text-muted">
                                        <i class="far fa-image fs-1 opacity-25 d-block mb-2"></i>
                                        <span>Chưa có hình ảnh</span>
                                    </div>
                                }
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Tải Lên Hình Ảnh Mới</label>
                                <input type="file" name="imageUrl" class="form-control" accept="image/*" />
                                <div class="form-text small">Để trống nếu muốn giữ nguyên hình ảnh hiện tại.</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 justify-content-end mt-5 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            <i class="fas fa-check me-1"></i> Lưu Thay Đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
