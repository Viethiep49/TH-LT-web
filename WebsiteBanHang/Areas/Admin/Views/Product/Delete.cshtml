@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white fs-5 fw-bold py-3">
                <i class="fas fa-exclamation-triangle me-2"></i> Xác Nhận Xóa
            </div>
            <div class="card-body p-4 p-md-5 text-center">
                <h4 class="card-title fw-bold mb-3">Bạn có chắc chắn muốn xóa sản phẩm này?</h4>
                <p class="text-muted mb-4">Hành động này không thể hoàn tác. Tất cả dữ liệu liên quan đến sản phẩm này sẽ bị mất vĩnh viễn.</p>
                
                <div class="bg-light p-3 rounded mb-4 d-flex align-items-center justify-content-center gap-4 text-start border">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="rounded shadow-sm object-fit-contain bg-white p-1 border" style="width: 100px; height: 100px;" alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="rounded bg-white border d-flex align-items-center justify-content-center text-muted shrink-0" style="width: 100px; height: 100px;">
                            <i class="far fa-image fs-1 opacity-25"></i>
                        </div>
                    }
                    
                    <div>
                        <h5 class="fw-bold mb-1">@Model.Name</h5>
                        <p class="text-success fw-bold mb-0">@Model.Price.ToString("#,##0") đ</p>
                        <span class="badge bg-secondary mt-1">ID: #@Model.Id</span>
                    </div>
                </div>

                <form asp-area="Admin" asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-area="Admin" asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-danger px-4 fw-semibold">
                            <i class="fas fa-trash-alt me-1"></i> Có, Hãy Xóa Nó
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
