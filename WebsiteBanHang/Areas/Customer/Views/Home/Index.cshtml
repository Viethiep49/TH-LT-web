@model IEnumerable<WebsiteBanHang.Models.Product>
@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="hero-section text-center py-5 mb-5 bg-white rounded border shadow-sm">
    <div class="container">
        <h1 class="display-5 fw-bold text-dark">Nhà Sách</h1>
        <p class="lead mb-0 text-muted">Hàng ngàn đầu sách đang chờ bạn khám phá.</p>
    </div>
</div>

<div id="books-list" class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Sách Mới Nhất</h4>
        <a asp-controller="Product" asp-action="Index" class="text-decoration-none small fw-semibold">Xem tất cả <i class="fas fa-chevron-right ms-1"></i></a>
    </div>
    
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-top transition-all bg-white">
                    <div class="position-relative overflow-hidden" style="padding-top: 140%;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="position-absolute top-0 start-0 w-100 h-100 object-fit-contain p-2" alt="@item.Name">
                        }
                        else
                        {
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center text-muted opacity-25">
                                <i class="fas fa-book fa-3x"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body p-3 text-center">
                        <h6 class="card-title fw-bold mb-2 text-truncate-2" title="@item.Name" style="min-height: 2.5em;">
                           <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">@item.Name</a>
                        </h6>
                        <p class="text-primary fw-bold mb-0">@item.Price.ToString("#,##0") đ</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-3 pt-0 text-center d-flex justify-content-center gap-2">
                         <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3">Chi tiết</a>
                         <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@item.Id" class="btn btn-primary btn-sm rounded-pill px-3">
                             <i class="bi bi-cart-plus"></i> Thêm
                         </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
