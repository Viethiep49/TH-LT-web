@{
    ViewData["Title"] = "Đặt hàng thành công";
}
@model int

<div class="container my-5 text-center">
    <div class="py-5">
        <div class="display-1 text-success mb-4">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <h2 class="fw-bold text-dark mb-3">Cảm ơn bạn đã đặt hàng!</h2>
        <p class="lead text-muted mb-4">Đơn hàng của bạn <strong>#@Model</strong> đã được hệ thống ghi nhận và đang được xử lý.</p>
        
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2">
                <i class="bi bi-arrow-left me-2"></i> Quay lại trang chủ
            </a>
            <!-- <a class="btn btn-outline-dark rounded-pill px-4 py-2">
                Theo dõi đơn hàng
            </a> -->
        </div>
    </div>
</div>
