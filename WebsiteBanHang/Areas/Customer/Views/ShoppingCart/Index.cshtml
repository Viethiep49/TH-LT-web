@model WebsiteBanHang.Models.ShoppingCart

@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4">Giỏ Hàng <i class="bi bi-cart3"></i></h2>

    @if (Model.Items.Count > 0)
    {
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="ps-4">Sản Phẩm</th>
                                        <th scope="col">Đơn Giá</th>
                                        <th scope="col" width="150">Số Lượng</th>
                                        <th scope="col">Thành Tiền</th>
                                        <th scope="col" class="text-end pe-4">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                    {
                                                        <img src="@item.ImageUrl" class="rounded object-fit-cover me-3" width="60" height="80" alt="@item.Name" />
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center text-muted" style="width: 60px; height: 80px;">
                                                            <i class="fas fa-book fa-2x"></i>
                                                        </div>
                                                    }
                                                    <span class="fw-semibold text-dark">@item.Name</span>
                                                </div>
                                            </td>
                                            <td>@item.Price.ToString("#,##0") đ</td>
                                            <td>
                                                <form asp-action="UpdateCart" method="post" class="d-flex align-items-center">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm text-center mx-1" style="width: 60px;" />
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Cập nhật"><i class="bi bi-arrow-clockwise"></i></button>
                                                </form>
                                            </td>
                                            <td class="fw-bold text-primary">@((item.Price * item.Quantity).ToString("#,##0")) đ</td>
                                            <td class="text-end pe-4">
                                                <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-action="ClearCart" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash3 me-1"></i> Xóa toàn bộ giỏ hàng</a>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Tóm Tắt Đơn Hàng</h5>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng phụ (@Model.GetTotalQuantity() sản phẩm)</span>
                            <span class="fw-semibold">@Model.ComputeTotalValue().ToString("#,##0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="text-success fw-semibold">Miễn phí</span>
                        </div>
                        
                        <hr class="my-4 opacity-25">
                        
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5">Tổng Tộng</span>
                            <span class="fw-bold fs-4 text-primary">@Model.ComputeTotalValue().ToString("#,##0") đ</span>
                        </div>
                        
                        <a asp-controller="ShoppingCart" asp-action="Checkout" class="btn btn-primary w-100 py-2 rounded-pill fw-bold mb-3">
                            Tiến Hành Thanh Toán <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                        
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light w-100 py-2 rounded-pill fw-semibold text-dark">
                            <i class="bi bi-arrow-left me-2"></i> Tiếp Tục Mua Sắm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4 text-muted">
                <i class="bi bi-cart-x" style="font-size: 5rem;"></i>
            </div>
            <h4 class="fw-bold text-dark mb-3">Giỏ hàng của bạn đang trống</h4>
            <p class="text-muted mb-4">Bạn chưa chọn sản phẩm nào vào giỏ hàng. Hãy khám phá kho sách của chúng tôi!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-pill">
                <i class="bi bi-cart-plus me-2"></i> Trở về Trang Chủ Mua Sắm
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto submit form when quantity changed directly
        document.querySelectorAll('input[name="quantity"]').forEach(input => {
            input.addEventListener('change', function() {
                this.closest('form').submit();
            });
        });
        
        // Prevent form submission if quantity < 1
        document.querySelectorAll('form[asp-action="UpdateCart"]').forEach(form => {
            form.addEventListener('submit', function(e) {
                const qtyInput = this.querySelector('input[name="quantity"]');
                if(parseInt(qtyInput.value) < 1) {
                    e.preventDefault();
                    qtyInput.value = 1;
                }
            });
        });
    </script>
}
