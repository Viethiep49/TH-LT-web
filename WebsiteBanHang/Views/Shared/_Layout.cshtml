<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --accent-color: #4cc9f0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fbff;
        }

        .navbar {
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }

        .grid-container {
            display: grid;
            grid-template-columns: 3fr 1fr;
            gap: 30px;
        }

        @@media (max-width: 992px) {
            .grid-container {
                grid-template-columns: 1fr;
            }
        }

        .sidebar {
            background: white;
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            height: fit-content;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            padding: 10px 24px;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background-color: var(--secondary-color);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(67, 97, 238, 0.3);
        }

        .social-links a {
            font-size: 20px;
            margin-right: 15px;
            color: #64748b;
            transition: all 0.3s;
            display: inline-block;
        }

        .social-links a:hover {
            color: var(--primary-color);
            transform: scale(1.2);
        }

        .nav-link {
            font-weight: 500;
            color: #475569 !important;
            transition: color 0.3s;
        }

        .nav-link:hover {
            color: var(--primary-color) !important;
        }

        .footer {
            background: #1e293b;
            color: #94a3b8;
        }

        .footer h5 {
            color: white;
            font-weight: 600;
        }

        .footer a {
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer a:hover {
            color: var(--accent-color);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-book me-2"></i>BookStore
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav pe-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Customer" asp-controller="Home" asp-action="Index">Trang Chủ</a>
                        </li>
                        @if (User.IsInRole(SD.Role_Admin))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-primary fw-bold" href="#" id="adminDropdown" data-bs-toggle="dropdown">
                                    Quản Trị viên
                                </a>
                                <ul class="dropdown-menu shadow border-0">
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Product" asp-action="Index">Quản lý Sách</a></li>
                                    <li><a class="dropdown-item" href="#">Quản lý Danh mục</a></li>
                                    <li><a class="dropdown-item" href="#">Quản lý Đơn hàng</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container min-vh-100">
        <div class="grid-container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
            <aside class="sidebar">
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Tìm Kiếm</h5>
                    <div class="input-group">
                        <input type="text" class="form-control border-end-0" placeholder="Tìm sách...">
                        <button class="btn btn-outline-primary border-start-0" type="button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>

                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Theo Dõi Chúng Tôi</h5>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <hr class="my-4 opacity-50" />

                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Liên Kết Nhanh</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted">Sản phẩm mới</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted">Khuyến mãi cực sốc</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted">Liên hệ hỗ trợ</a></li>
                    </ul>
                </div>
            </aside>
        </div>
    </div>

    <footer class="footer mt-5 py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="mb-4">BookStore</h5>
                    <p>Chuyên cung cấp các loại sách văn học, khoa học, giáo khoa và ngoại ngữ với chất lượng tốt nhất. Sự hài lòng của độc giả là ưu tiên hàng đầu của chúng tôi.</p>
                </div>
                <div class="col-lg-3 offset-lg-1">
                    <h5 class="mb-4">Liên Hệ</h5>
                    <ul class="list-unstyled">
                        <li class="mb-3"><i class="fas fa-map-marker-alt me-2 text-primary"></i> TP.HCM</li>
                        <li class="mb-3"><i class="fas fa-envelope me-2 text-primary"></i> contact@gmail.com</li>
                        <li class="mb-3"><i class="fas fa-phone me-2 text-primary"></i> 0123 456 789</li>
                    </ul>
                </div>
                <div class="col-lg-3 offset-lg-1">
                    <h5 class="mb-4">Hỗ Trợ Khách Hàng</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Điều khoản sử dụng</a></li>
                        <li class="mb-2"><a href="#">Chính sách bảo mật</a></li>
                        <li class="mb-2"><a href="#">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a href="#">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>
            </div>
            <div class="text-center pt-5 mt-5 border-top border-secondary">
                <p class="mb-0">&copy; 2026 - BookStore </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
